local trackedEnemies = {}

task.spawn(function()
    while true do
        task.wait(0.1)
        local es = Workspace:FindFirstChild("EnemySystem")
        local folder = es and es:FindFirstChild("ActiveEnemies")
        if folder then
            for _, enemy in ipairs(folder:GetChildren()) do
                local hum = enemy:FindFirstChildOfClass("Humanoid")
                if hum then
                    local prev = trackedEnemies[enemy]
                    if prev and prev > 0 and hum.Health <= 0 then
                        KillStats.Total += 1
                        KillStats.Session += 1
                        KillStats.LastKill = enemy.Name
                        local elapsed = math.max(1, os.time() - KillStats.SessionStart)
                        KillStats.PerMinute = math.floor((KillStats.Session / elapsed) * 60 * 10) / 10
                    end
                    trackedEnemies[enemy] = hum.Health
                end
            end
            for e in pairs(trackedEnemies) do
                if not e.Parent then trackedEnemies[e] = nil end
            end
        end
    end
end)

