local buyRangeValue = 9999

local function buyNearby(hrp)
    local count = 0
    local params = OverlapParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.FilterDescendantsInstances = {LocalPlayer.Character}

    local nearbyParts = Workspace:GetPartBoundsInRadius(hrp.Position, buyRangeValue, params)

    for _, part in ipairs(nearbyParts) do
        if not part:IsDescendantOf(Workspace.Tycoons) then continue end
        if not part:FindFirstChildOfClass("TouchTransmitter") then continue end

        -- Check if button is already purchased
        -- Walk up to find the button model and check ButtonActive BoolValue
        local buttonModel = part.Parent
        while buttonModel and not buttonModel.Parent:IsA("Folder") do
            buttonModel = buttonModel.Parent
        end

        local alreadyBought = false
        if buttonModel then
            local boolVal = buttonModel:FindFirstChild("ButtonActive")
            -- If ButtonActive is a BoolValue and it's false = already bought
            if boolVal and boolVal:IsA("BoolValue") and boolVal.Value == false then
                alreadyBought = true
            end
            -- If ButtonActive doesn't exist anymore = already bought
            if not boolVal then
                alreadyBought = true
            end
        end

        if not alreadyBought then
            pcall(function()
                firetouchinterest(hrp, part, 0)
                task.wait(0.05)
                firetouchinterest(hrp, part, 1)
            end)
            count += 1
        end
    end
    return count
end

