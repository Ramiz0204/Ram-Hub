-- GET ENEMIES
-- ================================================
local function getEnemies()
    local enemies = {}
    local enemySystem = Workspace:FindFirstChild("EnemySystem")
    if not enemySystem then return enemies end
    local folder = enemySystem:FindFirstChild("ActiveEnemies")
    if not folder then return enemies end
    for _, enemy in ipairs(folder:GetChildren()) do
        local root = enemy:FindFirstChild("HumanoidRootPart")
        local hum = enemy:FindFirstChildOfClass("Humanoid")
        if root and hum and hum.Health > 0 then
            table.insert(enemies, { model = enemy, root = root, hum = hum, name = enemy.Name })
        end
    end
    return enemies
end

local function getNearestEnemy()
    local char = LocalPlayer.Character
    if not char then return nil end
    local myRoot = char:FindFirstChild("HumanoidRootPart")
    if not myRoot then return nil end
    local myPos = myRoot.Position
    local nearest, nearestDist = nil, math.huge
    for _, e in ipairs(getEnemies()) do
        local dist = (e.root.Position - myPos).Magnitude
        if dist < nearestDist then
            nearestDist = dist
            nearest = { data = e, dist = dist }
        end
    end
    return nearest
end

