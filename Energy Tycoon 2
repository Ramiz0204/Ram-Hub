UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end

    -- F = Kill Aura Toggle
    if input.KeyCode == Enum.KeyCode.F then
        Config.KillAura = not Config.KillAura
        if Config.KillAura then
            if not auraThread then
                auraThread = task.spawn(function()
                    while Config.KillAura do
                        local weapon = getWeapon()
                        local char = LocalPlayer.Character
                        local hrp = char and char:FindFirstChild("HumanoidRootPart")
                        if weapon and hrp then
                            for _, enemy in ipairs(getEnemies()) do
                                if not Config.KillAura then break end
                                if enemy.root and enemy.root.Parent and enemy.hum.Health > 0 then
                                    fireOnEnemy(weapon, enemy)
                                end
                            end
                        end
                        task.wait(Config.AuraFireRate)
                    end
                    auraThread = nil
                end)
            end
            Rayfield:Notify({ Title = "💥 [F] Kill Aura ON", Content = "Aura aktiv!", Duration = 2 })
        else
            auraThread = nil
            Rayfield:Notify({ Title = "💥 [F] Kill Aura OFF", Content = "Gestoppt.", Duration = 2 })
        end
    end

    -- T = Sit Toggle
    if input.KeyCode == Enum.KeyCode.T then
        Config.SitEnabled = not Config.SitEnabled
        local es = Workspace:FindFirstChild("EnemySystem")
        local folder = es and es:FindFirstChild("ActiveEnemies")
        if folder then
            for _, enemy in ipairs(folder:GetChildren()) do
                local hum = enemy:FindFirstChildOfClass("Humanoid")
                if hum then pcall(function() hum.Sit = Config.SitEnabled end) end
            end
        end
        if Config.SitEnabled then
            Rayfield:Notify({ Title = "🪑 [T] Sit ON", Content = "Enemies eingefroren!", Duration = 2 })
        else
            Rayfield:Notify({ Title = "🪑 [T] Sit OFF", Content = "Enemies bewegen sich wieder.", Duration = 2 })
        end
    end
end)

-- ================================================
-- INFINITE AMMO (functions used by KillAura tab)
-- ================================================
local infAmmoThread = nil

local function setInfAmmo()
    local function applyToTool(tool)
        local config = tool:FindFirstChild("Configuration")
        if config then
            local ammo = config:FindFirstChild("AmmoCapacity")
            if ammo then pcall(function() ammo.Value = MAX_VALUE end) end
            local current = config:FindFirstChild("CurrentAmmo")
                or config:FindFirstChild("Ammo")
                or config:FindFirstChild("MagazineSize")
            if current then pcall(function() current.Value = MAX_VALUE end) end
        end
        for _, v in ipairs(tool:GetDescendants()) do
            if (v.Name:lower():find("ammo") or v.Name:lower():find("magazine"))
            and (v:IsA("IntValue") or v:IsA("NumberValue")) then
                pcall(function() v.Value = MAX_VALUE end)
            end
        end
    end
    local bp = LocalPlayer:FindFirstChild("Backpack")
    if bp then for _, t in ipairs(bp:GetChildren()) do if t:IsA("Tool") then applyToTool(t) end end end
    local char = LocalPlayer.Character
    if char then for _, t in ipairs(char:GetChildren()) do if t:IsA("Tool") then applyToTool(t) end end end
end

local function startInfAmmo()
    if infAmmoThread then return end
    infAmmoThread = task.spawn(function()
        while Config.InfAmmo do setInfAmmo() task.wait(0.1) end
        infAmmoThread = nil
    end)
end

LocalPlayer.CharacterAdded:Connect(function(char)
    char.ChildAdded:Connect(function(child)
        if child:IsA("Tool") and Config.InfAmmo then task.wait(0.1) setInfAmmo() end
    end)
end)
if LocalPlayer.Character then
    LocalPlayer.Character.ChildAdded:Connect(function(child)
        if child:IsA("Tool") and Config.InfAmmo then task.wait(0.1) setInfAmmo() end
    end)
end

