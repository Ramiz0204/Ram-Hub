local auraStatusLabel = KillAuraTab:CreateLabel("Status: Inaktiv")

KillAuraTab:CreateToggle({
    Name = "💥 Kill Aura (Auto TP + Sit + Kill)",
    CurrentValue = false,
    Flag = "KillAura",
    Callback = function(value)
        Config.KillAura = value
        Config.SitEnabled = value
        Config.AutoTPEnemies = value

        if value then
            -- Check: Hat der Player eine Waffe?
            local weapon = getWeapon()
            if not weapon then
                Config.KillAura = false
                Config.SitEnabled = false
                Config.AutoTPEnemies = false
                Rayfield:Notify({
                    Title = "⚠️ Keine Waffe!",
                    Content = "Du musst in einer Mob Area sein mit einer Waffe!",
                    Duration = 4,
                })
                return
            end

            -- Check: Gibt es Enemies?
            local enemies = getEnemies()
            if #enemies == 0 then
                Rayfield:Notify({
                    Title = "⚠️ Keine Enemies!",
                    Content = "Du musst in einer Mob Area sein mit einer Waffe!",
                    Duration = 4,
                })
                -- Trotzdem starten, vielleicht spawnen gleich welche
            end

            if auraThread then return end
            auraThread = task.spawn(function()
                while Config.KillAura do
                    local wp = getWeapon()
                    local char = LocalPlayer.Character
                    local hrp = char and char:FindFirstChild("HumanoidRootPart")

                    if not wp then
                        auraStatusLabel:Set("⚠️ Keine Waffe gefunden!")
                        task.wait(1)
                        continue
                    end

                    if hrp then
                        local es = Workspace:FindFirstChild("EnemySystem")
                        local folder = es and es:FindFirstChild("ActiveEnemies")
                        if folder then
                            local list = folder:GetChildren()
                            for i, enemy in ipairs(list) do
                                if not Config.KillAura then break end

                                local root = enemy:FindFirstChild("HumanoidRootPart")
                                local hum = enemy:FindFirstChildOfClass("Humanoid")

                                if root and hum then
                                    -- Auto Sit
                                    if not hum.Sit then
                                        pcall(function() hum.Sit = true end)
                                    end

                                    -- Auto TP zu Player (Kreis)
                                    local angle = (i / #list) * math.pi * 2
                                    local offset = Vector3.new(math.cos(angle) * 4, 0, math.sin(angle) * 4)
                                    pcall(function()
                                        root.CFrame = hrp.CFrame * CFrame.new(offset)
                                    end)

                                    -- Kill
                                    if hum.Health > 0 then
                                        local eData = { root = root, hum = hum, name = enemy.Name, model = enemy }
                                        fireOnEnemy(wp, eData)
                                    end
                                end
                            end
                            auraStatusLabel:Set("Status: 💥 AKTIV | Enemies: " .. #list)
                        else
                            auraStatusLabel:Set("⚠️ Keine Mob Area gefunden!")
                        end
                    end

                    task.wait(Config.AuraFireRate)
                end
                auraThread = nil
                auraStatusLabel:Set("Status: Inaktiv")
            end)

            Rayfield:Notify({
                Title = "💥 Kill Aura ON",
                Content = "Auto TP + Sit + Kill aktiv!",
                Duration = 3,
            })
        else
            auraThread = nil
            auraStatusLabel:Set("Status: Inaktiv")
            -- Sit ausschalten
            local es = Workspace:FindFirstChild("EnemySystem")
            local folder = es and es:FindFirstChild("ActiveEnemies")
            if folder then
                for _, enemy in ipairs(folder:GetChildren()) do
                    local hum = enemy:FindFirstChildOfClass("Humanoid")
                    if hum then pcall(function() hum.Sit = false end) end
                end
            end
            Rayfield:Notify({ Title = "💥 Kill Aura OFF", Content = "Gestoppt.", Duration = 2 })
        end
    end,
})

