-- ================================================
-- FIRE ON SINGLE ENEMY
-- ================================================
local shotID = 1

local function fireOnEnemy(weapon, enemyData)
    local char = LocalPlayer.Character
    local myRoot = char and char:FindFirstChild("HumanoidRootPart")
    if not myRoot or not weapon then return end

    local origin = myRoot.Position
    local root = enemyData.root
    local enemyPos = root.Position + Vector3.new(0, 1, 0)
    local dir = (enemyPos - origin).Unit
    local dist = (enemyPos - origin).Magnitude

    -- Step 1: WeaponFired (starts the bullet)
    pcall(function()
        WeaponFired:FireServer(weapon, {
            id     = shotID,
            charge = 0,
            origin = origin,
            dir    = dir,
        })
    end)

    -- Step 2: WeaponHit (registers the damage on enemy)
    pcall(function()
        WeaponHit:FireServer(weapon, {
            p       = enemyPos,
            pid     = shotID,
            part    = root,
            d       = dist,
            maxDist = dist + 999,
            h       = root,
            m       = Enum.Material.SmoothPlastic,
            n       = Vector3.yAxis,
            t       = 0,
            sid     = shotID,
        })
    end)

    shotID += 1
end

