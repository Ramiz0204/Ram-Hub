local shootThread = nil

local function startAutoShoot()
    if shootThread then return end
    shootThread = task.spawn(function()
        while Config.HookEnabled do
            local weapon = getWeapon()
            if weapon then
                for _, enemy in ipairs(getEnemies()) do
                    if not Config.HookEnabled then break end
                    fireOnEnemy(weapon, enemy)
                    task.wait(0.05)
                end
            end
            task.wait(Config.FireDelay)
        end
        shootThread = nil
    end)
end

