-- Auto-sit loop: friert neue Enemies ein sobald sie spawnen
task.spawn(function()
    while true do
        task.wait(0.3)
        if Config.SitEnabled then
            local es = Workspace:FindFirstChild("EnemySystem")
            local folder = es and es:FindFirstChild("ActiveEnemies")
            if folder then
                for _, enemy in ipairs(folder:GetChildren()) do
                    local hum = enemy:FindFirstChildOfClass("Humanoid")
                    if hum and not hum.Sit then
                        pcall(function() hum.Sit = true end)
                    end
                end
            end
        end

        -- Auto TP enemies to player
        if Config.AutoTPEnemies then
            local char = LocalPlayer.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            if hrp then
                local es = Workspace:FindFirstChild("EnemySystem")
                local folder = es and es:FindFirstChild("ActiveEnemies")
                if folder then
                    for i, enemy in ipairs(folder:GetChildren()) do
                        local root = enemy:FindFirstChild("HumanoidRootPart")
                        if root then
                            -- Spread enemies in circle around player so they dont stack
                            local angle = (i / #folder:GetChildren()) * math.pi * 2
                            local offset = Vector3.new(math.cos(angle) * 5, 0, math.sin(angle) * 5)
                            pcall(function()
                                root.CFrame = hrp.CFrame * CFrame.new(offset)
                            end)
                        end
                    end
                end
            end
        end
    end
end)

