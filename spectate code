-- Enhanced Spectate Library
local SpectateLib = {}
local selectedPlayer = nil
local isSpectating = false
local autoSpectateEnabled = false

function SpectateLib.setLocalCamera()
    spawn(function()
        local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
        local hum = char:WaitForChild("Humanoid", 5)
        if hum then Camera.CameraSubject = hum end
    end)
end

function SpectateLib.startSpectate(playerName)
    if playerName == LocalPlayer.Name then return false, "Cannot spectate yourself" end
    local targetPlayer = Players:FindFirstChild(playerName)
    if targetPlayer and targetPlayer.Character and targetPlayer.Character:FindFirstChildOfClass("Humanoid") then
        Camera.CameraSubject = targetPlayer.Character:FindFirstChildOfClass("Humanoid")
        selectedPlayer = playerName
        isSpectating = true
        return true, "Spectating " .. playerName
    end
    return false, "Player not found or invalid"
end

function SpectateLib.stopSpectate()
    SpectateLib.setLocalCamera()
    selectedPlayer = nil
    isSpectating = false
    return true, "Stopped spectating"
end

function SpectateLib.toggleSpectate(playerName)
    if isSpectating then return SpectateLib.stopSpectate()
    elseif playerName then return SpectateLib.startSpectate(playerName) end
    return false, "No player selected"
end

function SpectateLib.getPlayerList()
    local players = {}
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then table.insert(players, player.Name) end
    end
    return players
end

-- ESP System
local ESPConnections = {}
function createESP(player)
    if player == LocalPlayer or not player.Character then return end
    local highlight = Instance.new("Highlight")
    highlight.FillColor = Color3.fromRGB(255, 0, 0)
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.FillTransparency = 0.5
    highlight.OutlineTransparency = 0
    highlight.Parent = player.Character
    highlight.Adornee = player.Character
    
    local billboard = Instance.new("BillboardGui")
    billboard.Size = UDim2.new(0, 200, 0, 50)
    billboard.StudsOffset = Vector3.new(0, 3, 0)
    billboard.Parent = player.Character.Head
    
    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(1, 0, 0.5, 0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = player.Name
    nameLabel.TextColor3 = Color3.new(1,1,1)
    nameLabel.TextScaled = true
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.Parent = billboard
    
    local distanceLabel = Instance.new("TextLabel")
    distanceLabel.Size = UDim2.new(1, 0, 0.5, 0)
    distanceLabel.Position = UDim2.new(0, 0, 0.5, 0)
    distanceLabel.BackgroundTransparency = 1
    distanceLabel.Text = "0m"
    distanceLabel.TextColor3 = Color3.new(0.8,0.8,0.8)
    distanceLabel.TextScaled = true
    distanceLabel.Font = Enum.Font.Gotham
    distanceLabel.Parent = billboard
    
    ESPConnections[player] = {highlight = highlight, billboard = billboard}
end

function toggleESP(enabled)
    local ESPEnabled = enabled
    if enabled then
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then createESP(player) end
        end
        local heartbeatConn
        heartbeatConn = RunService.Heartbeat:Connect(function()
            if not ESPEnabled then heartbeatConn:Disconnect() return end
            for player, esp in pairs(ESPConnections) do
                if player.Character and player.Character.Parent and player.Character:FindFirstChild("Head") then
                    local distance = (LocalPlayer.Character.HumanoidRootPart.Position - player.Character.HumanoidRootPart.Position).Magnitude
                    esp.distanceLabel.Text = math.floor(distance) .. "m"
                end
            end
        end)
    else
        for _, esp in pairs(ESPConnections) do
            if esp.highlight then esp.highlight:Destroy() end
            if esp.billboard then esp.billboard:Destroy() end
        end
        ESPConnections = {}
    end
end

-- Movement System
local flying = false
local flyConnection
local noclipping = false
local noclipConnection
local MovementSpeed = 16

function toggleFly(enabled)
    flying = enabled
    if enabled and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        local bodyVelocity = Instance.new("BodyVelocity")
        bodyVelocity.MaxForce = Vector3.new(4000, 4000, 4000)
        bodyVelocity.Velocity = Vector3.new(0, 0, 0)
        bodyVelocity.Parent = LocalPlayer.Character.HumanoidRootPart
        
        flyConnection = RunService.Heartbeat:Connect(function()
            if not flying or not LocalPlayer.Character or not LocalPlayer.Character.HumanoidRootPart then
                bodyVelocity:Destroy()
                return
            end
            local cam = Workspace.CurrentCamera.CFrame
            local speed = MovementSpeed
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then bodyVelocity.Velocity = cam.LookVector * speed end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then bodyVelocity.Velocity = -cam.LookVector * speed end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then bodyVelocity.Velocity = -cam.RightVector * speed end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then bodyVelocity.Velocity = cam.RightVector * speed end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then bodyVelocity.Velocity = Vector3.new(bodyVelocity.Velocity.X, speed, bodyVelocity.Velocity.Z) end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then bodyVelocity.Velocity = Vector3.new(bodyVelocity.Velocity.X, -speed, bodyVelocity.Velocity.Z) end
        end)
    else
        if flyConnection then flyConnection:Disconnect() end
    end
end

function toggleNoclip(enabled)
    noclipping = enabled
    if noclipConnection then noclipConnection:Disconnect() end
    if enabled then
        noclipConnection = RunService.Stepped:Connect(function()
            if LocalPlayer.Character then
                for _, part in pairs(LocalPlayer.Character:GetChildren()) do
                    if part:IsA("BasePart") then part.CanCollide = false end
                end
            end
        end)
    end
end

