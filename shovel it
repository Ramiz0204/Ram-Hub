local TpIceTab = Window:CreateTab("🧊 Auto TP Ice", 4483362458)
TpIceTab:CreateSection("Auto TP zu Ice Blocks")
TpIceTab:CreateLabel("Teleportiert zu Ice Blocks, wartet dann weiter")

local tpStatusLabel  = TpIceTab:CreateLabel("Status: Inaktiv")
local tpBlockLabel   = TpIceTab:CreateLabel("Block: -")
local tpCountLabel   = TpIceTab:CreateLabel("TPs: 0 | Blocks gefunden: 0")
local tpTimerLabel   = TpIceTab:CreateLabel("Timer: -")

TpIceTab:CreateToggle({
    Name = "🧊 Auto TP AN/AUS",
    CurrentValue = false,
    Flag = "AutoTP",
    Callback = function(value)
        Config.AutoTP = value
        if value then
            if tpThread then return end
            tpThread = task.spawn(function()
                local visitedBlocks = {}
                local loopCount = 0

                while Config.AutoTP do
                    local blocks = getIceBlocks()
                    tpCountLabel:Set("TPs: " .. totalTPs .. " | Blocks: " .. #blocks)

                    if #blocks == 0 then
                        tpStatusLabel:Set("⏳ Keine Ice Blocks gefunden!")
                        task.wait(2)
                        continue
                    end

                    -- Find next unvisited block
                    local block = nil
                    for _, b in ipairs(blocks) do
                        if not visitedBlocks[b.id] then
                            block = b
                            break
                        end
                    end

                    -- All visited → reset and loop again
                    if not block then
                        loopCount += 1
                        visitedBlocks = {}
                        tpStatusLabel:Set("🔄 Loop #" .. loopCount .. " | Alle Blocks fertig, starte neu!")
                        task.wait(0.5)
                        block = blocks[1]
                    end

                    if block then
                        visitedBlocks[block.id] = true

                        local char = LocalPlayer.Character
                        local hrp = char and char:FindFirstChild("HumanoidRootPart")

                        if hrp and block.pos then
                            hrp.CFrame = CFrame.new(block.pos + Vector3.new(0, 3, 0))
                            totalTPs += 1

                            local visited = 0
                            for _ in pairs(visitedBlocks) do visited += 1 end
                            tpCountLabel:Set("TPs: " .. totalTPs .. " | " .. visited .. "/" .. #blocks .. " besucht")
                            tpBlockLabel:Set("Block ID: " .. block.id .. " | Loop #" .. loopCount)
                            tpStatusLabel:Set("✅ AKTIV | " .. visited .. "/" .. #blocks)

                            for i = Config.WaitTime, 1, -1 do
                                if not Config.AutoTP then break end
                                tpTimerLabel:Set("⏱️ Nächster Block in: " .. i .. "s")
                                char = LocalPlayer.Character
                                hrp = char and char:FindFirstChild("HumanoidRootPart")
                                if hrp then
                                    hrp.CFrame = CFrame.new(block.pos + Vector3.new(0, 3, 0))
                                end
                                task.wait(1)
                            end
                        else
                            task.wait(0.5)
                        end
                    end
                end
                tpThread = nil
                tpStatusLabel:Set("Status: Inaktiv")
                tpTimerLabel:Set("Timer: -")
            end)
            Rayfield:Notify({ Title = "🧊 Auto TP ON", Content = "Teleportiert zu " .. Config.AreaName .. " Blocks!", Duration = 3 })
        else
            tpThread = nil
            tpStatusLabel:Set("Status: Inaktiv")
            tpTimerLabel:Set("Timer: -")
            Rayfield:Notify({ Title = "🧊 Auto TP OFF", Content = "Gestoppt.", Duration = 2 })
        end
    end,
})

