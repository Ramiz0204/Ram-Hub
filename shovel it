-- ================================================
-- GET ICE BLOCKS
-- ================================================
local function getIceBlocks()
    local blocks = {}
    local snowFolder = Workspace:FindFirstChild("Snow")
    if not snowFolder then return blocks end
    local partsFolder = snowFolder:FindFirstChild("Parts")
    if not partsFolder then return blocks end
    local areaFolder = partsFolder:FindFirstChild(Config.AreaName)
    if not areaFolder then return blocks end

    for _, visualFolder in ipairs(areaFolder:GetChildren()) do
        for _, idFolder in ipairs(visualFolder:GetChildren()) do
            local id = tonumber(idFolder.Name)
            if id then
                -- Get position from Visual child
                local visual = idFolder:FindFirstChild("Visual")
                local pos = nil
                if visual then
                    if visual:IsA("BasePart") then
                        pos = visual.Position
                    else
                        local bp = visual:FindFirstChildOfClass("BasePart")
                        if bp then pos = bp.Position end
                    end
                end
                if not pos then
                    local bp = idFolder:FindFirstChildOfClass("BasePart")
                    if bp then pos = bp.Position end
                end
                if pos then
                    table.insert(blocks, { id = id, folder = idFolder, pos = pos })
                end
            end
        end
    end
    return blocks
end

