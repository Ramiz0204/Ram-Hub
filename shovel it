local gearThread = nil
local gearCount = 0
local gearStatusLabel = ShopsTab:CreateLabel("Status: Inaktiv | Gekauft: 0")
local GearPurchaseRemote = ReplicatedStorage
    :WaitForChild("Packages")
    :WaitForChild("Knit")
    :WaitForChild("Services")
    :WaitForChild("GearsShopService")
    :WaitForChild("RF")
    :WaitForChild("Purchase")

local function buyAllGearItems()
    local bought = 0
    -- Try IDs 1-20 (all possible gear slots)
    for id = 1, 20 do
        local ok, result = pcall(function()
            return GearPurchaseRemote:InvokeServer(id)
        end)
        if ok and result then
            bought += 1
            gearCount += 1
        end
        task.wait(0.2)
    end
    return bought
end

