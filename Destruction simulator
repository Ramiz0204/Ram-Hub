                    end
                    -- Also fire remote directly
                    pcall(function() SellRemote:FireServer() end)
                    sellCount += 1
                    sellStatusLabel:Set("Status: ✅ AKTIV | Sold: " .. sellCount)
                    task.wait(sellDelay)
