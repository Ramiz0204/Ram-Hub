                local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
                local hrp = char:FindFirstChild("HumanoidRootPart")

                -- TP to sell spot first
                local sellSpot = Workspace:FindFirstChild("sellSpot")
                if sellSpot and hrp then
                    local sellPart = sellSpot:FindFirstChildOfClass("BasePart") or sellSpot
                    if sellPart:IsA("BasePart") then
                        pcall(function() hrp.CFrame = sellPart.CFrame + Vector3.new(0, 3, 0) end)
                    end
                end

                while Config.AutoSell do
                    -- firetouchinterest on sellSpot
                    local spot = Workspace:FindFirstChild("sellSpot")
                    local ch = LocalPlayer.Character
                    local root = ch and ch:FindFirstChild("HumanoidRootPart")
                    if spot and root then
                        for _, part in ipairs(spot:GetDescendants()) do
